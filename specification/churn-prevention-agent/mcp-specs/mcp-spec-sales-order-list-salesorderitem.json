{
  "server": "sap.mcpbuilder:apiResource:sales_order_mcp_demo:v1",
  "server_name": "sales_order_mcp_demo",
  "name": "list_salesorderitem",
  "title": "list_A_SalesOrderItem",
  "description": "Retrieve a list of entities from the A_SalesOrderItem collection in the api_sales_order_srv service. Supports OData query options for filtering, sorting, ranking ($top), skipping ($skip), expanding related entities, counting, selecting specific properties.",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": [],
    "properties": {
      "filter": {
        "title": "filter",
        "description": "OData $filter expression. E.g. filter by SalesOrder or SalesDocumentRjcnReason for returns.",
        "type": "string",
        "examples": ["SalesOrder eq '1000001'", "SalesDocumentRjcnReason ne ''"]
      },
      "select": {
        "title": "select",
        "description": "OData $select query option.",
        "type": "string",
        "examples": ["SalesOrder,SalesOrderItem,Material,NetAmount,SalesDocumentRjcnReason,OrderRelatedBillingStatus"]
      },
      "orderby": { "title": "orderby", "type": "string" },
      "top": { "title": "top", "type": "integer", "minimum": 0 },
      "skip": { "title": "skip", "type": "integer", "minimum": 0 },
      "expand": { "title": "expand", "type": "string" },
      "inlinecount": { "title": "inlinecount", "type": "string", "enum": ["allpages", "none"] }
    }
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "value": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "SalesOrder": { "type": "string" },
            "SalesOrderItem": { "type": "string" },
            "Material": { "type": "string" },
            "NetAmount": { "type": "string" },
            "TransactionCurrency": { "type": "string" },
            "SalesDocumentRjcnReason": { "type": "string", "description": "Rejection/return reason code" },
            "OrderRelatedBillingStatus": { "type": "string" },
            "SDProcessStatus": { "type": "string" }
          }
        }
      }
    }
  }
}
